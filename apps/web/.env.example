# No LLM API key is required to run this demo. Agent responses are scripted; the
# cryptographic identity layer (resolve, sign, verify, mint) is fully real.

# Optional. Directory for server-held state (keystore.json, registry.json).
# Defaults to the repo's backend/ dir locally, or the OS temp dir on read-only
# serverless filesystems (where state is ephemeral across cold starts).
# HACD_DATA_DIR=/var/data/hacd
